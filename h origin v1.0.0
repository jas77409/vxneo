[32m+[m[32m## 🏗️ Architecture[m
[32m+[m[32m```[m
[32m+[m[32m┌─────────────────────────────────────────┐[m
[32m+[m[32m│         NGINX (Port 443)                │[m
[32m+[m[32m│         SSL Termination                  │[m
[32m+[m[32m└──────────────┬──────────────────────────┘[m
[32m+[m[32m               │[m
[32m+[m[32m        ┌──────▼───────┐[m
[32m+[m[32m        │  VXNeo Web   │ (SvelteKit - Port 3000)[m
[32m+[m[32m        └──────┬───────┘[m
[32m+[m[32m               │[m
[32m+[m[32m    ┌──────────┼──────────────┐[m
[32m+[m[32m    │          │              │[m
[32m+[m[32m┌───▼───┐  ┌───▼────┐  ┌─────▼─────┐[m
[32m+[m[32m│ Redis │  │Supabase│  │Browserless│[m
[32m+[m[32m│(Cache)│  │  (DB)  │  │(Scraping) │[m
[32m+[m[32m└───────┘  └───┬────┘  └───────────┘[m
[32m+[m[32m               │[m
[32m+[m[32m        ┌──────┴──────┐[m
[32m+[m[32m        │             │[m
[32m+[m[32m    ┌───▼────┐  ┌─────▼──────┐[m
[32m+[m[32m    │ Audit  │  │  Scraper   │[m
[32m+[m[32m    │ Worker │  │  Worker    │[m
[32m+[m[32m    └────────┘  └────────────┘[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m## 🛠️ Tech Stack[m
[32m+[m
[32m+[m[32m**Frontend:**[m
[32m+[m[32m- SvelteKit - Full-stack framework[m
[32m+[m[32m- Tailwind CSS - Styling[m
[32m+[m[32m- TypeScript - Type safety[m
[32m+[m
[32m+[m[32m**Backend:**[m
[32m+[m[32m- Node.js 20 - Runtime[m
[32m+[m[32m- Supabase - PostgreSQL database + Auth[m
[32m+[m[32m- Redis - Caching and queuing[m
[32m+[m
[32m+[m[32m**Workers:**[m
[32m+[m[32m- Background audit processing[m
[32m+[m[32m- Data broker scraping[m
[32m+[m[32m- Automated recommendations[m
[32m+[m
[32m+[m[32m**Infrastructure:**[m
[32m+[m[32m- Docker & Docker Compose[m
[32m+[m[32m- NGINX - Reverse proxy[m
[32m+[m[32m- Prometheus & Grafana - Monitoring[m
[32m+[m
[32m+[m[32m## 🔐 Security[m
[32m+[m
[32m+[m[32m- Passwordless authentication via magic links[m
[32m+[m[32m- Secure httpOnly cookies for session management[m
[32m+[m[32m- Row Level Security (RLS) in database[m
[32m+[m[32m- Environment-based secrets management[m
[32m+[m[32m- SSL/TLS encryption in production[m
[32m+[m
[32m+[m[32m**Reporting Security Issues:** Please email security@vxneo.com[m
[32m+[m
[32m+[m[32m## 📊 Database Schema[m
[32m+[m
[32m+[m[32mMain tables:[m
[32m+[m[32m- `audit_requests` - Audit queue and status[m
[32m+[m[32m- `audit_results` - Detailed audit findings[m
[32m+[m[32m- `removal_requests` - Data broker removal tracking[m
[32m+[m[32m- `profiles` - User profile information[m
[32m+[m
[32m+[m[32mSee database migrations in `supabase/migrations/` for complete schema.[m
[32m+[m
[32m+[m[32m## 🧪 Testing[m
